# ResumAI Backend Configuration
# Copy this file to .env and fill in actual values

# Application settings
APP_NAME=ResumAI
APP_VERSION=0.1.0
DEBUG=true

# API settings
API_PREFIX=/api

# LLM Provider settings
# Configure after deciding which LLM to use
LLM_PROVIDER=

# GCP / GCS settings
GCP_PROJECT_ID=resumai-platform
GCS_BUCKET_NAME=resumai-platform-resumes
GCS_OBJECT_PREFIX=resumes
# If set, this will be used to create the GCS client; otherwise ADC is used.
GCS_CREDENTIALS_PATH=./.secrets/gcp-storage-sa.json
# Or set GOOGLE_APPLICATION_CREDENTIALS in your shell environment

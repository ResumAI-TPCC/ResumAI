# ResumAI Backend Configuration
# Copy this file to .env and fill in actual values

# Application settings
APP_NAME=ResumAI
APP_VERSION=0.1.0
DEBUG=true

# API settings
API_PREFIX=/api

# LLM Provider settings
LLM_PROVIDER=gemini

# Gemini settings
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2048
GEMINI_TIMEOUT=60.0
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY=1.0

# GCP / GCS settings
GCP_PROJECT_ID=resumai-platform
GCS_BUCKET_NAME=resumai-platform-resumes
GCS_OBJECT_PREFIX=resumes
# For local development, run `gcloud auth application-default login` to set up ADC.

# Helicone settings
HELICONE_API_KEY=your-helicone-api-key-here
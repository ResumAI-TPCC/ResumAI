# ResumAI Backend Configuration
# Copy this file to .env and fill in actual values

# Application settings
APP_NAME=ResumAI
APP_VERSION=0.1.0
DEBUG=true

# API settings
API_PREFIX=/api

# LLM Provider settings
LLM_PROVIDER=gemini

# Gemini settings
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

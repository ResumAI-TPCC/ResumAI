# ResumAI Backend Configuration
# Copy this file to .env and fill in actual values

# Application settings
APP_NAME=ResumAI
APP_VERSION=0.1.0
DEBUG=true

# API settings
API_PREFIX=/api

# LLM Provider settings
LLM_PROVIDER=gemini

# Gemini API settings
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# GCP / GCS settings
GCP_PROJECT_ID=resumai-platform
GCS_BUCKET_NAME=resumai-platform-resumes
GCS_OBJECT_PREFIX=resumes
# For local development, run `gcloud auth application-default login` to set up ADC.

{
    "compilerOptions": {
        /**
     * types
     * 指定 TypeScript 在编译/类型检查时
     * 自动加载哪些“全局类型定义”
     * 这里写 ["jest"] 的含义是：
     * - 在测试文件中允许直接使用 test / expect / describe
     * - 不需要每个测试文件手动 import 这些类型
     * 如果没有这一项：
     * - TypeScript 会报错：Cannot find name 'test' / 'expect'
     */
        "types": [
            "jest"
        ],
        /**
     * jsx
     * 告诉 TypeScript：这个项目中会存在 .tsx / JSX 语法
     * "react-jsx" 是 React 17+ 推荐的写法：
     * - 不需要显式 import React
     * - 兼容现代前端工具链（Vite / React 18）
     * 即使你现在测试的是“纯逻辑”，
     * 只要 import 了 .tsx 文件（如 App.tsx），
     * 这一项就是必须的
     */
        "jsx": "react-jsx"
    }
}